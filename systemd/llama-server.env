# /etc/llama-server.env
#
# Environment overrides for llama-server.service.
# Edit this file and `sudo systemctl restart llama-server` to apply changes.

# --- Model -------------------------------------------------------------------
# Absolute path to the GGUF checkpoint.
MODEL_PATH=/models/gemma-4-31b-it/gemma-4-31b-it-nvfp4.gguf

# --- Network -----------------------------------------------------------------
# Use 127.0.0.1 to restrict to localhost (recommended behind a reverse proxy).
# Use 0.0.0.0 to expose on the LAN.
HOST=0.0.0.0
PORT=8080

# --- Inference ---------------------------------------------------------------
# Tokens of context the server keeps for each conversation.
CTX_SIZE=16384

# 999 means "all layers on GPU". On GB10 with unified memory, always use 999.
N_GPU_LAYERS=999

# CPU threads for non-offloaded operations.
# Grace CPU has 10 Cortex-X925 + 10 Cortex-A725 cores; 16 is a safe default.
THREADS=16

# Concurrent request slots. Each slot reserves its own KV cache.
# Memory cost per slot ~= ctx_size * num_layers * 2 * (bytes per kv element).
PARALLEL=4

# Prefill chunking. Larger = faster long-prompt prefill, more memory.
BATCH_SIZE=2048
UBATCH_SIZE=512
