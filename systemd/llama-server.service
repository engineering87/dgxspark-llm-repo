[Unit]
Description=LLama.cpp Server (Gemma 31B)
After=network-online.target
Wants=network-online.target

[Service]
User=dgxspark
WorkingDirectory=/home/dgxspark/llama.cpp

ExecStart=/home/dgxspark/llama.cpp/build/bin/llama-server \
  -m /models/gemma-4-31B-it-NVFP4-turbo/gemma-4-31B-it-NVFP4-turbo-NVFP4.gguf \
  -c 8192 \
  --n-gpu-layers 100 \
  --host 0.0.0.0 \
  --port 8080

Restart=always
RestartSec=5
Environment=CUDA_VISIBLE_DEVICES=0

[Install]
WantedBy=multi-user.target
